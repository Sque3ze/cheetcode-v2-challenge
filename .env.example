# ── Required ──────────────────────────────────────────────────────────────────

# Convex deployment URL (written automatically by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Shared secret for server ↔ Convex authentication
# Must also be set on Convex side: npx convex env set CONVEX_MUTATION_SECRET <value>
# Generate: openssl rand -hex 32
CONVEX_MUTATION_SECRET=replace-with-strong-secret

# Server secret for seed-based challenge data generation
# This MUST be kept secret — it's what prevents answer precomputation
# Generate: openssl rand -hex 32
SERVER_SECRET=replace-with-random-64-char-hex-secret

# ── Auth (pick one) ──────────────────────────────────────────────────────────

# Option A: Skip GitHub OAuth entirely (local dev only)
DEV_USER=your-github-username
# NEXT_PUBLIC_DEV_USER=your-github-username   # also needed for client-side pages

# Option B: Real GitHub OAuth (production / full auth flow)
# AUTH_GITHUB_ID=replace-with-github-oauth-client-id
# AUTH_GITHUB_SECRET=replace-with-github-oauth-client-secret
# AUTH_SECRET=replace-with-random-32-byte-secret

# ── Optional ─────────────────────────────────────────────────────────────────

# Admin dashboard access (visit /admin?key=<ADMIN_KEY>)
# ADMIN_GITHUB=your-github-username
# ADMIN_KEY=replace-with-admin-secret

# Base URL for OG image / share links (defaults to https://cheetcode.dev)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# E2E testing
# NEXT_PUBLIC_TEST_MODE=true          # enables data-* test selectors
# TEST_AUTH_SECRET=replace-with-test-secret  # test auth bypass token
